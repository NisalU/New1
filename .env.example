# AI Trading Signal Bot — environment variables
# Copy this file to .env and fill in your keys.
# The server reads .env automatically at startup (python-dotenv).
# Keys set in the environment always take priority over .env.

# ── Required for AI analysis ─────────────────────────────────────────────────
# Free key from https://openrouter.ai/keys
# Free tier: 50 requests / UTC day
OPENROUTER_API_KEY=

# Optional: override the default model (default: tencent/hunyuan-a13b-instruct:free)
# Other free options: meta-llama/llama-3.1-8b-instruct:free, mistralai/mistral-7b-instruct:free
# OPENROUTER_MODEL=tencent/hunyuan-a13b-instruct:free

# ── Optional: Binance API (higher rate limits + private endpoints) ────────────
# Public market data works without these; they only raise your rate limit cap
# and enable authenticated endpoints (account info, order placement).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Optional: CoinMarketCap (enriches coin scanner with market-cap data) ──────
CMC_API_KEY=
